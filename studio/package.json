{
  "name": "badminton-borne-studio",
  "private": true,
  "version": "1.0.0",
  "description": "Sanity Studio voor Badminton Borne",
  "scripts": {
    "dev": "sanity dev",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "typegen": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "seed": "sanity exec scripts/seed.ts --with-user-token",
    "seed:team": "sanity exec scripts/seed-team.ts --with-user-token"
  },
  "dependencies": {
    "@sanity/icons": "^3",
    "@sanity/vision": "^6",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "sanity": "^6",
    "styled-components": "^6.1.15"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19",
    "typescript": "^5"
  }
}
