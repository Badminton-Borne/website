# Frontend (frontend/.env.local) — studio/scripts/setup-sanity.py vult dit automatisch
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=your_viewer_token
NEXT_PUBLIC_SITE_URL=https://badmintonborne.nl

# Contactformulier + nieuwsbrief-opslag (API-routes): token met Editor-rechten
# (aanmaken op sanity.io/manage → API → Tokens, alleen server-side gebruiken)
SANITY_API_WRITE_TOKEN=your_editor_token

# Optioneel: nieuwsbrief direct naar Laposta i.p.v. opslaan in Sanity
LAPOSTA_API_KEY=
LAPOSTA_LIST_ID=

# Studio (studio/.env) — idem via setup-sanity.py
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production

# Optioneel: Google reviews (nog niet in gebruik)
GOOGLE_PLACES_API_KEY=your_google_places_api_key
